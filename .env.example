# =============================================================================
# Atlas Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# AI Provider
# Atlas uses the Vercel AI SDK with an OpenAI-compatible endpoint.
# Point this at LiteLLM, OpenAI, or any OpenAI-compatible proxy.
# -----------------------------------------------------------------------------

# Base URL of the OpenAI-compatible API endpoint.
# Default points to a local LiteLLM proxy (http://localhost:4000).
# For OpenAI directly: https://api.openai.com/v1
ATLAS_AI_BASE_URL=http://localhost:4000

# API key for the AI provider. Required.
# If using LiteLLM, this is your LiteLLM master key.
# If using OpenAI directly, this is your sk-... key.
ATLAS_AI_API_KEY=sk-placeholder

# Default model identifier in provider/model format.
# Examples: openai/gpt-4o-mini, anthropic/claude-3-5-sonnet, openai/gpt-4o
ATLAS_AI_MODEL=openai/gpt-4o-mini

# -----------------------------------------------------------------------------
# Redis (Event Bus Pub/Sub, BullMQ Job Queues, Caching)
# -----------------------------------------------------------------------------

# Redis connection URL.
# Default connects to a local Redis instance started via `bash compose.sh up -d`.
ATLAS_REDIS_URL=redis://localhost:6379

# Prefix for all Redis keys Atlas creates.
# Useful when sharing a Redis instance across multiple environments or apps.
ATLAS_REDIS_KEY_PREFIX=atlas:

# -----------------------------------------------------------------------------
# PostgreSQL (Event Persistence, Session Store, Migrations)
# -----------------------------------------------------------------------------

# PostgreSQL connection URL.
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
# Default matches the credentials in docker/compose.yaml.
ATLAS_POSTGRES_URL=postgres://atlas:atlas@localhost:5432/atlas

# Maximum number of concurrent connections in the postgres.js pool.
# Lower this for development; raise for production workloads.
ATLAS_POSTGRES_MAX_CONNECTIONS=10

# -----------------------------------------------------------------------------
# OpenTelemetry (Tracing, Metrics, Logs)
# Atlas uses manual instrumentation only — no auto-patching.
# -----------------------------------------------------------------------------

# OTLP exporter endpoint (HTTP/protobuf protocol).
# Default points to the local OTel Collector from compose.yaml.
# Set to empty string or remove to disable telemetry export.
ATLAS_OTEL_COLLECTOR_ENDPOINT=http://localhost:4318

# Service name shown in traces and metrics.
ATLAS_OTEL_SERVICE_NAME=atlas

# Service version for tracking deployments.
ATLAS_OTEL_SERVICE_VERSION=0.0.1

# Deployment environment tag (e.g., development, staging, production).
ATLAS_OTEL_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Graphiti (Episodic Memory via Knowledge Graph)
# Graphiti runs as a REST service backed by FalkorDB (Redis-based graph DB).
# -----------------------------------------------------------------------------

# Base URL of the Graphiti REST API.
# Default matches the port exposed in docker/compose.yaml.
ATLAS_GRAPHITI_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# HTTP Server
# -----------------------------------------------------------------------------

# Port for the Atlas HTTP server (webhooks, health check).
# Default is 3000.
ATLAS_PORT=3000

# -----------------------------------------------------------------------------
# Slack Adapter (Optional)
# Only needed if you want Atlas to receive/send messages via Slack.
# Create a Slack app at https://api.slack.com/apps to get these values.
# -----------------------------------------------------------------------------

# OAuth bot token (starts with xoxb-).
# Leave empty to disable the Slack adapter.
ATLAS_SLACK_BOT_TOKEN=

# Signing secret for verifying webhook payloads from Slack.
# Found in your Slack app's "Signing Secret" section.
ATLAS_SLACK_SIGNING_SECRET=

# -----------------------------------------------------------------------------
# Discord Adapter (Optional)
# Only needed if you want Atlas to receive/send messages via Discord.
# Create a bot at https://discord.com/developers/applications.
# -----------------------------------------------------------------------------

# Discord bot token (from the "Bot" page in your application settings).
# Leave empty to disable the Discord adapter.
ATLAS_DISCORD_BOT_TOKEN=

# Discord application ID (from the "General Information" page).
ATLAS_DISCORD_APPLICATION_ID=

# -----------------------------------------------------------------------------
# Linear Adapter (Optional)
# Only needed if you want Atlas to interact with Linear issues.
# Create an API key at https://linear.app/settings/api.
# -----------------------------------------------------------------------------

# Personal or workspace API key for Linear.
# Leave empty to disable the Linear adapter.
ATLAS_LINEAR_API_KEY=

# Webhook secret for verifying Linear webhook payloads.
# Set this if you configure Linear webhooks pointing to Atlas.
ATLAS_LINEAR_WEBHOOK_SECRET=
